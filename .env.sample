# Required for OpenWeather geocoding and short-range forecast
OPENWEATHER_API_KEY=

# Optional timeouts (seconds)
OPENWEATHER_TIMEOUT_SECONDS=30
OPENMETEO_TIMEOUT_SECONDS=30

# Optional holiday cache override
HOLIDAY_CACHE_FILE=.cache/holidays_cache.txt

# Optional Feishu weather report overrides
FEISHU_WEBHOOK_URL=https://www.feishu.cn/flow/api/trigger-webhook/xxxx
WEATHER_REPORT_CITY=Beijing
